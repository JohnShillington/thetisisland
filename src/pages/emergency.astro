---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const page = await getEntry("pages", "emergency");
const { Content } = await render(page);
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <section class="mx-auto max-w-4xl px-4 py-12">
    <h1 class="text-3xl font-bold text-primary mb-4">{page.data.title}</h1>
    <p class="text-text-muted mb-10">What to do and where to find help when you need it.</p>

    <!-- Fire hazard rating — placeholder for Stage 5 auto-scraper -->
    <div class="bg-accent text-white p-6 rounded-lg mb-10">
      <h2 class="text-xl font-semibold mb-2">Fire Danger Today</h2>
      <p class="mb-3">Always check the official rating before burning or using outdoor flames.</p>
      <a href="https://www.thetisislandfire.ca/burn-table.html" target="_blank" rel="noopener noreferrer" class="font-medium underline">See today's fire hazard rating on the TIVFD website &rarr;</a>
    </div>

    <div class="prose max-w-none text-text">
      <Content />
    </div>
  </section>
</BaseLayout>
