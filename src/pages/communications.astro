---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const page = await getEntry("pages", "communications");
const { Content } = await render(page);
---

<BaseLayout title={page.data.title} description={page.data.description}>
  <section class="mx-auto max-w-4xl px-4 py-12">
    <h1 class="text-3xl font-bold text-primary mb-4">Community Communications</h1>
    <p class="text-text-muted mb-10">Stay informed and connected on Thetis Island.</p>

    <div class="prose max-w-none text-text">
      <Content />
    </div>
  </section>
</BaseLayout>
