---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Thank You" description="Your submission has been received.">
  <section class="mx-auto max-w-4xl px-4 py-20 text-center">
    <h1 class="text-3xl font-bold text-primary mb-4">Thank You!</h1>
    <p class="text-text mb-6">Your submission has been received. TIRRA will follow up with you shortly.</p>
    <a href="/" class="text-accent font-medium hover:underline">&larr; Back to home</a>
  </section>
</BaseLayout>
