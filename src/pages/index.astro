---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Home">
  <section class="bg-primary/80 text-white py-20 text-center">
    <div class="mx-auto max-w-3xl px-4">
      <h1 class="text-3xl sm:text-4xl font-bold mb-4">Welcome to Thetis Island</h1>
      <p class="text-lg opacity-90">Your gateway to community services, resources and visitor information for our beautiful Gulf Island.</p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12">
    <h2 class="text-2xl font-bold text-primary mb-8 text-center">Find What You Need</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="bg-surface rounded-lg shadow p-6">
        <h3 class="font-semibold text-primary mb-2">Ferry Info</h3>
        <p class="text-sm text-text-muted">Check the BC Ferries schedule and webcams to plan your trip.</p>
      </div>
      <div class="bg-surface rounded-lg shadow p-6">
        <h3 class="font-semibold text-primary mb-2">Our Services</h3>
        <p class="text-sm text-text-muted">TIRRA-managed services including solid waste, trails, cemetery and more.</p>
      </div>
      <div class="bg-surface rounded-lg shadow p-6">
        <h3 class="font-semibold text-primary mb-2">Community &amp; Groups</h3>
        <p class="text-sm text-text-muted">Connect with local organizations, clubs and volunteer groups.</p>
      </div>
      <div class="bg-surface rounded-lg shadow p-6">
        <h3 class="font-semibold text-primary mb-2">Visitors</h3>
        <p class="text-sm text-text-muted">Travel tips, accommodations and recreation ideas for visitors.</p>
      </div>
      <div class="bg-surface rounded-lg shadow p-6">
        <h3 class="font-semibold text-primary mb-2">Emergency</h3>
        <p class="text-sm text-text-muted">Emergency contacts, fire danger levels and preparedness information.</p>
      </div>
      <div class="bg-surface rounded-lg shadow p-6">
        <h3 class="font-semibold text-primary mb-2">Calendar</h3>
        <p class="text-sm text-text-muted">See upcoming events across the island in our combined community calendar.</p>
      </div>
    </div>
  </section>
</BaseLayout>
