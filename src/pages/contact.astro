---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact" description="Contact TIRRA — mailing address, email and key contacts.">
  <section class="mx-auto max-w-4xl px-4 py-12">
    <h1 class="text-3xl font-bold text-primary mb-4">Contact Us</h1>
    <p class="text-text-muted mb-10">We'd love to hear from you.</p>

    <div class="space-y-10">
      <div>
        <h2 class="text-xl font-semibold text-primary mb-3">General Inquiries</h2>
        <p class="text-text mb-3">For questions about TIRRA services, membership, website feedback or general island inquiries:</p>
        <p class="text-text"><strong><a href="mailto:info@thetisisland.net" class="text-accent hover:underline">info@thetisisland.net</a></strong></p>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-primary mb-3">Mailing Address</h2>
        <address class="text-text not-italic">
          Thetis Island Residents &amp; Ratepayers Association<br>
          P.O. Box 000<br>
          Thetis Island, BC V0R 2Y0<br>
          Canada
        </address>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-primary mb-3">Website Feedback</h2>
        <p class="text-text">If you notice outdated information or would like to suggest additions to this website, please contact <a href="mailto:webmaster@thetisisland.net" class="text-accent hover:underline">webmaster@thetisisland.net</a>.</p>
      </div>
    </div>
  </section>
</BaseLayout>
