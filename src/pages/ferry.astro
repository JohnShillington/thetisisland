---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const page = await getEntry("pages", "ferry");
const { Content } = await render(page);
---

<BaseLayout title="Ferry Info" description={page.data.description}>
  <section class="mx-auto max-w-4xl px-4 py-12">
    <h1 class="text-3xl font-bold text-primary mb-4">Ferry Information</h1>
    <p class="text-text-muted mb-10">Schedules, webcams and live vessel tracking for the Chemainus–Thetis–Penelakut route.</p>

    <div class="prose max-w-none text-text mb-10">
      <Content />
    </div>

    <!-- Snake ferry schedule — placeholder for Stage 5 -->
    <div class="space-y-10">
      <div>
        <h2 class="text-xl font-semibold text-primary mb-3">Snake Schedule</h2>
        <div class="bg-surface border-2 border-dashed border-primary/20 rounded-lg p-8 text-center text-text-muted">
          <p class="text-sm">Visual snake ferry schedule coming in a future update.</p>
          <p class="text-sm mt-2">In the meantime, see the <a href="https://www.bcferries.com/routes-fares/schedules/seasonal/THT-CHM" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">BC Ferries schedule</a>.</p>
        </div>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-primary mb-3">Chemainus Terminal Webcam</h2>
        <p class="text-text mb-3">View current traffic at the Chemainus ferry terminal. The image refreshes automatically every 60 seconds.</p>
        <div class="bg-surface border rounded-lg overflow-hidden mb-2">
          <img
            src="https://ccimg.bcferries.com/cc/support/terminals/cam1_CHM.jpg"
            alt="Chemainus Terminal Webcam"
            class="webcam w-full"
            data-src="https://ccimg.bcferries.com/cc/support/terminals/cam1_CHM.jpg"
          />
        </div>
        <p class="text-xs text-text-muted mb-1">Image source: BC Ferries</p>
        <a href="https://www.bcferries.com/current-conditions/CHM-THT" target="_blank" rel="noopener noreferrer" class="text-accent text-sm hover:underline">View on BC Ferries site &rarr;</a>
      </div>

      <div>
        <h2 class="text-xl font-semibold text-primary mb-3">Thetis Island Ferry Cam</h2>
        <p class="text-text mb-3">This camera shows the Thetis Island ferry lineup. The image refreshes automatically every 60 seconds.</p>
        <div class="bg-surface border rounded-lg overflow-hidden mb-2">
          <img
            src="https://www.thetisisland.net/ferry/camera/cars.jpg"
            alt="Thetis Island Ferry Cam"
            class="webcam w-full"
            data-src="https://www.thetisisland.net/ferry/camera/cars.jpg"
          />
        </div>
        <p class="text-xs text-text-muted mb-1">Image source: Thetis Island community camera</p>
        <a href="https://www.thetisisland.net/ferry/index.html" target="_blank" rel="noopener noreferrer" class="text-accent text-sm hover:underline">View on Thetis Island website &rarr;</a>
      </div>
    </div>
  </section>

  <script>
    // --- Webcam auto-refresh (bfcache-safe) ---
    const REFRESH_INTERVAL = 60_000;
    let refreshTimer: ReturnType<typeof setInterval> | null = null;

    function refreshWebcams() {
      const cacheBuster = `_t=${Date.now()}`;
      document.querySelectorAll("img.webcam").forEach((img) => {
        const base = img.getAttribute("data-src");
        if (base) {
          const sep = base.includes("?") ? "&" : "?";
          (img as HTMLImageElement).src = `${base}${sep}${cacheBuster}`;
        }
      });
    }

    function startRefresh() {
      if (refreshTimer !== null) clearInterval(refreshTimer);
      refreshWebcams();                              // immediate refresh on (re)start
      refreshTimer = setInterval(refreshWebcams, REFRESH_INTERVAL);
    }

    function stopRefresh() {
      if (refreshTimer !== null) {
        clearInterval(refreshTimer);
        refreshTimer = null;
      }
    }

    // Start on initial load
    startRefresh();

    // Safari bfcache: restart the timer when the page is restored
    window.addEventListener("pageshow", (e) => {
      if (e.persisted) startRefresh();
    });

    // Pause when the page is about to enter bfcache
    window.addEventListener("pagehide", () => {
      stopRefresh();
    });

    // --- Open external links in new tabs ---
    document.querySelectorAll(".prose a[href]").forEach((a) => {
      const href = a.getAttribute("href") || "";
      if (href.startsWith("http") && !href.includes(window.location.hostname)) {
        a.setAttribute("target", "_blank");
        a.setAttribute("rel", "noopener noreferrer");
      }
    });
  </script>
</BaseLayout>
